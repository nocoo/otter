# ===========================================
# Otter — Local development env vars
# ===========================================
# Copy to packages/web/.env and fill in:
#   cp .env.example packages/web/.env
#
# Vite reads variables prefixed with OTTER_ from packages/web/.env
# (loadEnv pulls from cwd of the vite process, which is packages/web/).

# -------------------------------------------
# Vite dev server (`bun run dev`)
# -------------------------------------------
# Vite's dev server proxies /api/* to a real Cloudflare Worker so the SPA
# can be debugged against production data without running a local worker.
#
# Defaults to https://otter.nocoo.workers.dev (the workers.dev fallback,
# Bearer-only — bypasses Cloudflare Access SSO). The custom domain
# https://otter.hexly.ai works the same way once your local DNS resolver
# learns the new record (CF Access still falls through to Bearer auth).
# OTTER_API_URL=https://otter.nocoo.workers.dev

# Bearer token injected by the vite proxy as `Authorization: Bearer <token>`.
# Mint one by opening (after Cloudflare Access SSO):
#   https://otter.hexly.ai/api/auth/cli?callback=http://127.0.0.1:65535/cb&state=mint
# The 302 redirect carries the token as `?token=otk_...`. apiKeyAuth verifies
# it against the api_tokens table in D1.
# OTTER_DEV_API_TOKEN=
