# ===========================================
# Otter - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# Vite Dev Server (packages/web local development)
# -------------------------------------------
# Vite dev server proxies /api/* to a real Worker so you can debug the SPA
# against production data. Defaults to https://otter.nocoo.workers.dev.
# OTTER_API_URL=https://otter.nocoo.workers.dev

# Bearer token injected into proxied /api/* requests during local dev.
# Mint a long-lived API token via /api/auth/cli on the prod Worker, then put
# it here. Vite adds it as `Authorization: Bearer <token>` so apiKeyAuth lets
# the request through without going through CF Access SSO.
# OTTER_DEV_API_TOKEN=
