{
  "name": "otter-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "bun run --filter '*' build",
    "lint": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json && tsc --noEmit -p packages/web/tsconfig.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
