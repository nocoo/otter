{
  "name": "otter-monorepo",
  "version": "1.3.6",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "bun run --cwd packages/web dev",
    "build": "bun run --filter '*' build",
    "lint": "tsc -p packages/core/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json && tsc --noEmit -p packages/web/tsconfig.json",
    "lint:biome": "bunx biome check .",
    "lint:biome:fix": "bunx biome check --write .",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "test:e2e:ui": "bun run scripts/run-e2e-ui.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,jsonc,css}": [
      "bunx biome check --write --error-on-warnings --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "fast-xml-parser": ">=5.5.7",
    "flatted": ">=3.4.2",
    "hono": ">=4.12.7",
    "brace-expansion": ">=5.0.5",
    "path-to-regexp": ">=8.4.0",
    "picomatch": ">=4.0.4"
  }
}
