{
  "name": "otter-monorepo",
  "version": "2.0.2",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:l2": "vitest run --config vitest.l2.config.ts",
    "dev": "bun run --cwd packages/web dev",
    "dev:worker": "bun run --cwd packages/worker dev",
    "build": "bun run --cwd packages/web build",
    "deploy": "bun run build && bun run --cwd packages/worker deploy",
    "lint": "bash scripts/typecheck-parallel.sh",
    "typecheck": "bash scripts/typecheck-parallel.sh",
    "lint:biome": "bunx biome check .",
    "lint:biome:fix": "bunx biome check --write .",
    "test:e2e": "bun run --cwd packages/web playwright test --config e2e/playwright.config.ts",
    "test:e2e:bdd": "bunx playwright test",
    "release": "bun run scripts/release.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,jsonc,css}": [
      "bunx biome check --write --error-on-warnings --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": ">=0.28.1",
    "hono": "$hono",
    "vite": ">=8.0.16",
    "path-to-regexp": ">=8.4.0",
    "picomatch": ">=4.0.4",
    "postcss": ">=8.5.10",
    "wrangler": ">=4.100.0",
    "ws": ">=8.20.1"
  },
  "dependencies": {
    "hono": "^4.12.25"
  }
}