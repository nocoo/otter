{
  "name": "otter-monorepo",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:l2": "vitest run --config vitest.l2.config.ts",
    "verify:test-db": "bun run scripts/verify-test-resources.ts",
    "dev": "bun run --cwd packages/web dev",
    "dev:worker": "bun run --cwd packages/worker dev",
    "build": "bun run --cwd packages/web build",
    "deploy": "bun run build && bun run --cwd packages/worker deploy",
    "deploy:test": "bun run build && bun run --cwd packages/worker deploy:test",
    "lint": "bash scripts/typecheck-parallel.sh",
    "lint:biome": "bunx biome check .",
    "lint:biome:fix": "bunx biome check --write .",
    "test:e2e": "bun run --cwd packages/web playwright test --config e2e/playwright.config.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,jsonc,css}": [
      "bunx biome check --write --error-on-warnings --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "hono": ">=4.12.14",
    "vite": ">=7.3.2",
    "path-to-regexp": ">=8.4.0",
    "picomatch": ">=4.0.4",
    "postcss": ">=8.5.10",
    "wrangler": ">=4.59.1"
  }
}
