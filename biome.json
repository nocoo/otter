{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "packages/*/src/**",
      "!**/*.css",
      "packages/web/e2e/**",
      "packages/web/test-support/**",
      "scripts/**",
      "vitest.config.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": "error",
      "complexity": {
        "recommended": true,
        "noExcessiveLinesPerFunction": "off",
        "noVoid": "off"
      },
      "correctness": {
        "recommended": true,
        "noNodejsModules": "off",
        "noUnresolvedImports": "off",
        "noUndeclaredDependencies": "off"
      },
      "performance": {
        "recommended": true,
        "useTopLevelRegex": "warn",
        "noAwaitInLoops": "warn",
        "noDelete": "warn",
        "noBarrelFile": "off",
        "noReExportAll": "off"
      },
      "security": {
        "recommended": true
      },
      "suspicious": {
        "recommended": true,
        "noConsole": "off",
        "useAwait": "warn",
        "noEmptyBlockStatements": "error",
        "noArrayIndexKey": "error"
      },
      "style": {
        "recommended": true,
        "noDefaultExport": "off",
        "noNonNullAssertion": "error",
        "useComponentExportOnlyModules": "error"
      }
    },
    "domains": {
      "next": "all",
      "react": "all"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/web/src/components/ui/**"],
      "linter": {
        "rules": {
          "a11y": "off",
          "style": {
            "useNamingConvention": "off",
            "useComponentExportOnlyModules": "off"
          }
        }
      }
    },
    {
      "includes": ["**/__tests__/**", "**/*.test.ts", "**/*.spec.ts", "**/test-support/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "security": {
            "noSecrets": "off"
          }
        }
      }
    }
  ]
}
