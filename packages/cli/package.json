{
  "name": "@nocoo/otter",
  "version": "1.0.3",
  "description": "Backup and restore your Mac development environment configuration",
  "type": "module",
  "bin": {
    "otter": "dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nocoo/otter.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "macos",
    "backup",
    "dotfiles",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "citty": "^0.1.0",
    "consola": "^3.4.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@otter/core": "workspace:*",
    "@types/node": "^25.3.4"
  }
}
