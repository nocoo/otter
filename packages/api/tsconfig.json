{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "composite": false,
    "allowJs": false,
    "types": ["node"],
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsc-api.tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/__tests__/e2e"]
}
