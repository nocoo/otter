#!/usr/bin/env sh
# Pre-push: G2 security gates in parallel.
# osv-scanner (lockfile vulnerabilities) + gitleaks (full git history secret scan).
# gitleaks runs at pre-commit too (staged-only), this is the deeper full-history scan.
set -o pipefail

TMPDIR_HOOK=$(mktemp -d -t otter-prepush-XXXXXX)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

( osv-scanner scan --lockfile=bun.lock --config=.osv-scanner.toml >"$TMPDIR_HOOK/osv.log" 2>&1; echo $? >"$TMPDIR_HOOK/osv.exit" ) &
OSV_PID=$!
( gitleaks git --no-banner -v >"$TMPDIR_HOOK/gitleaks.log" 2>&1; echo $? >"$TMPDIR_HOOK/gitleaks.exit" ) &
GITLEAKS_PID=$!

wait "$OSV_PID" 2>/dev/null || true
wait "$GITLEAKS_PID" 2>/dev/null || true

OSV_STATUS=$(cat "$TMPDIR_HOOK/osv.exit" 2>/dev/null || echo 1)
GITLEAKS_STATUS=$(cat "$TMPDIR_HOOK/gitleaks.exit" 2>/dev/null || echo 1)

echo "━━━ osv-scanner (exit=$OSV_STATUS) ━━━"
cat "$TMPDIR_HOOK/osv.log"
echo "━━━ gitleaks (exit=$GITLEAKS_STATUS) ━━━"
cat "$TMPDIR_HOOK/gitleaks.log"

[ "$OSV_STATUS" -eq 0 ] || { echo "❌ pre-push: osv-scanner failed" >&2; exit "$OSV_STATUS"; }
[ "$GITLEAKS_STATUS" -eq 0 ] || { echo "❌ pre-push: gitleaks failed" >&2; exit "$GITLEAKS_STATUS"; }

echo "✅ pre-push: G2 (osv + gitleaks) passed."
