#!/usr/bin/env sh
# Pre-commit: parallel stage orchestration via Bun.spawn (scripts/precommit.ts).
# G1 (lint-staged Biome) + L1 (vitest tests, coverage at pre-push) + tsc + gitleaks (staged).
