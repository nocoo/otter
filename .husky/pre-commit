#!/usr/bin/env sh

# G1: Biome lint + format (incremental, staged files only)
bunx lint-staged 2>&1
LINT_STAGED_EXIT=$?

if [ $LINT_STAGED_EXIT -ne 0 ]; then
  echo "❌ G1 FAILED: Biome lint/format errors on staged files."
  exit 1
fi

# L1: Unit Tests + Coverage Thresholds (≥90%)
bun run test:coverage 2>&1
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo "❌ L1 FAILED: Unit tests or coverage thresholds did not pass."
  exit 1
fi

# Type checking (tsc strict)
bun run lint 2>&1
TSC_EXIT=$?

if [ $TSC_EXIT -ne 0 ]; then
  echo "❌ Type check FAILED: TypeScript errors found."
  exit 1
fi

echo "✅ G1 (Biome) + L1 (UT) + tsc passed."
